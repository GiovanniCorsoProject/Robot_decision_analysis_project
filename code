from dataclasses import dataclass
import random
import math
from typing import List

# CLASSE OPZIONE

@dataclass(frozen=True)
class MissionOption:
    name: str
    benefit: float
    cost: float
    stress: float

    def __post_init__(self):
        if self.stress > 0:
            raise ValueError(
                f"Incorrect stress value for option '{self.name}': "
                "stress must be a negative value (such as -0.5)"
            )


# VALORE DELLA MISSIONE

def mission_choice_value(
    benefit: float,
    cost: float,
    stress: float,
    V1: float = 1.0,
    V2: float = 1.0,
    V3: float = 1.0
) -> float:
    if stress > 0:
        raise ValueError("stress must be a negative value (such as -0.5)")

    return V1 * benefit - V2 * cost + V3 * stress


# ROBOT 1 – RAZIONALE (MAXIMIZING)

class Robot1_maximizing:
    def __init__(self,
        V1: float = 1.0,
        V2: float = 1.0,
        V3: float = 1.0
    ):
        self.name = "Robot 1"
        self.V1 = V1
        self.V2 = V2
        self.V3 = V3

    def choose_action_Robot1(self, options: List[MissionOption]) -> int:
        """
        Sceglie l'opzione con valore massimo secondo mission_choice_value.
        Ritorna l'indice dell'opzione scelta nella lista 'options'.
        In caso di pari merito, sceglie casualmente tra le migliori.
        """
        values = [
            mission_choice_value(
                benefit=o.benefit,
                cost=o.cost,
                stress=o.stress,
                V1=self.V1,
                V2=self.V2,
                V3=self.V3
            )
            for o in options
        ]

        best_value = max(values)
        best_candidates = [i for i, v in enumerate(values) if v == best_value]

        return random.choice(best_candidates)


# ROBOT 2 – PROBABILISTICO (VALORE → PROBABILITÀ)

class Robot2_probabilistic:
    def __init__(self,
                 V1: float = 1.0,
                 V2: float = 1.0,
                 V3: float = 1.0,
                 instinct: float = 1.25):


        self.name = "Robot 2"
        self.V1 = V1
        self.V2 = V2
        self.V3 = V3
        self.instinct = instinct

    def choose_action_Robot2(self, options: List[MissionOption]) -> int:
        """Scelta probabilistica via softmax dei valori di missione."""
        values = [
            mission_choice_value(o.benefit, o.cost, o.stress, self.V1, self.V2, self.V3)
            for o in options
        ]

        # Softmax stabile: sottraiamo il massimo
        max_v = max(values)
        weights = [math.exp((v - max_v) / self.instinct) for v in values]

        # Estrai un indice con probabilità proporzionale ai pesi
        return random.choices(range(len(options)), weights=weights, k=1)[0]

# ROBOT 3 – RANGE-AWARE (UNCERTAINTY)

class Robot3_range_aware:
    def __init__(self,
                 V1: float = 1.0,
                 V2: float = 1.0,
                 V3: float = 1.0,
                 range_factor: float = 2.66):
        """
        Robot 3 non conosce i valori esatti di benefit, cost e stress.
        A partire dai valori nominali inseriti, costruisce automaticamente
        un range di incertezza:

            lower = value / range_factor
            upper = value * range_factor

        range_factor > 1 controlla l'ampiezza dell'incertezza.
        """


        self.name = "Robot 3"
        self.V1 = V1
        self.V2 = V2
        self.V3 = V3
        self.range_factor = range_factor

    def _compute_range(self, value: float) -> tuple:
        """Restituisce (lower_bound, upper_bound) del range."""
        lower = value / self.range_factor
        upper = value * self.range_factor
        return lower, upper

    def choose_action_Robot3(self, options: List[MissionOption]) -> int:
        """
        Strategia prudente (worst-case):
        - costruisce un range per ogni parametro
        - calcola il LOWER BOUND del valore di missione
        - sceglie l'opzione con lower bound massimo

        Ritorna l'indice dell'opzione scelta.
        """
        lower_bounds = []

        for o in options:
            benefit_low, benefit_up = self._compute_range(o.benefit)
            cost_low, cost_up = self._compute_range(o.cost)
            stress_low, stress_up = self._compute_range(o.stress)

            # Worst-case utility:
            # benefit -> minimo
            # cost    -> massimo
            # stress  -> minimo (più negativo)
            worst_value = mission_choice_value(
                benefit=benefit_low,
                cost=cost_up,
                stress=stress_low,
                V1=self.V1,
                V2=self.V2,
                V3=self.V3
            )

            lower_bounds.append(worst_value)

        best_value = max(lower_bounds)
        best_candidates = [i for i, v in enumerate(lower_bounds) if v == best_value]

        return random.choice(best_candidates)



